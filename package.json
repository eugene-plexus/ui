  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3"
