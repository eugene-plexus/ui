    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "codegen": "node scripts/codegen.mjs"
  },
  "dependencies": {
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
